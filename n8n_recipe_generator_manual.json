      "parameters": {
        "jsCode": "const results = $input.first().json.results || [];\nconst recipeName = $('Validate Recipe Name').first().json.recipe_name;\n\nlet imageUrl;\nif (results.length > 0) {\n  imageUrl = results[0].urls.regular.split('?')[0] + '?w=1200&q=80';\n} else {\n  // Fall back to AI-generated image if Unsplash returns nothing\n  const prompt = encodeURIComponent('professional food photography ' + recipeName + ' delicious appetizing styled dish overhead shot');\n  imageUrl = 'https://image.pollinations.ai/prompt/' + prompt + '?width=1200&height=800&nologo=true&model=flux';\n}\n\nreturn [{ json: { recipe_name: recipeName, image_url: imageUrl } }];"
      },
