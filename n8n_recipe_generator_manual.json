    {
      "parameters": {
        "jsCode": "const msg = $json.message;\nconst text = (msg && msg.text || '').trim();\nconst chatId = msg && msg.chat && msg.chat.id;\n\nif (!text || text.length === 0) {\n  return [{ json: { valid: false, recipe_name: '', chat_id: chatId } }];\n}\n\n// Strip any leading slash commands e.g. /generate Lobster Bisque -> Lobster Bisque\nconst recipeName = text.startsWith('/') ? text.split(' ').slice(1).join(' ').trim() : text;\n\nif (!recipeName) {\n  return [{ json: { valid: false, recipe_name: '', chat_id: chatId } }];\n}\n\nreturn [{ json: { valid: true, recipe_name: recipeName, chat_id: chatId } }];"
      },
